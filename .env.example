# Reddit API credentials
# Get these at https://www.reddit.com/prefs/apps (create a "script" app)
REDDIT_CLIENT_ID=your_client_id_here
REDDIT_CLIENT_SECRET=your_client_secret_here
REDDIT_USER_AGENT=social-pipeline/1.0

# S3 / MinIO (defaults work with docker-compose out of the box)
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=social-data

# Pipeline tuning
SUBREDDITS=wallstreetbets,investing,stocks
BATCH_SIZE=50
BATCH_TIMEOUT=30

# Demo mode — set to true to run without Reddit credentials
# Generates synthetic posts at DEMO_PPM posts per minute
DEMO_MODE=false
DEMO_PPM=120
