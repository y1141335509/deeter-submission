# ----------------------------------------------------------------------
# S3 / MinIO (defaults work with docker-compose out of the box)
# ----------------------------------------------------------------------
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=social-data

# ----------------------------------------------------------------------
# Ingestion mode
#
#   DEMO_MODE=false  → connect to Bluesky Jetstream firehose (public, no auth).
#   DEMO_MODE=true   → generate synthetic posts (no network needed).
#
# Live mode is the default. Switch to demo for offline development / CI.
# ----------------------------------------------------------------------
DEMO_MODE=false
DEMO_PPM=120

# ----------------------------------------------------------------------
# Pipeline tuning
# ----------------------------------------------------------------------
BATCH_SIZE=50
BATCH_TIMEOUT=30
DEDUP_WINDOW=3600

# ----------------------------------------------------------------------
# Bluesky firehose
#   FIREHOSE_QUEUE_SIZE              max in-memory backlog before drops
#   FIREHOSE_CURSOR_PATH             where to persist resume cursor
#   FIREHOSE_CURSOR_SAVE_INTERVAL    seconds between cursor flushes
# ----------------------------------------------------------------------
FIREHOSE_QUEUE_SIZE=2000
FIREHOSE_CURSOR_PATH=/var/lib/pipeline/cursor
FIREHOSE_CURSOR_SAVE_INTERVAL=10
